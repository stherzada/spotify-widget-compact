# Spotify app credentials — register one app at
# https://developer.spotify.com/dashboard and add the redirect URI below
# to that app's settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Local dev: http://127.0.0.1:3000/api/auth/callback
# Production: https://<your-domain>/api/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# KV store for widget sessions (refresh tokens). Provision an Upstash Redis
# database (directly, or via the Vercel Marketplace) and copy its REST
# credentials here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
